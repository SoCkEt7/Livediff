root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.rs]
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[LICENSE*]
indent_style = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
